# PixelFlow business persistence.
# Use URL-encoded credentials when passwords contain special characters.
# Example password character "!" may be kept as-is, but characters like @ / : ? # should be encoded.
PIXELFLOW_MYSQL_URL=mysql+asyncmy://<user>:<password>@<host>:3306/pixelflow?charset=utf8mb4

# Optional P1 semantic memory placeholder. P0 structured preferences do not use it.
PIXELFLOW_MEM0_ENABLED=false

# Borgrise / LLM secrets are intentionally not filled in here.
BORGRISE_API_TOKEN=
ANTHROPIC_API_KEY=
